Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "generates", " ", "samples", " ", "from", " ", "the", " ", 
    "Uniform", " ", "Distribution", " ", "with", " ", "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "1"}], ")"}], " ", 
    RowBox[{"(", "u", ")"}], " ", "and", " ", "an", " ", "observation", " ", 
    "from", " ", "the", " ", "Uniform", " ", "Distribution", " ", "with", " ",
     "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "2"}], ")"}], " ", 
    RowBox[{"(", "y", ")"}], " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"proposed", " ", "distrbution"}], ")"}], ".", " ", "Both"}], 
    " ", "samples", " ", "are", " ", "stored", "  ", "as", " ", "a", " ", 
    "pair", " ", "in", " ", "the", " ", "previously", " ", "defined", " ", 
    RowBox[{"table", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"unisamples", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"u", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], "]"}]}], " ", ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "2"}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pair", "=", 
      RowBox[{"{", 
       RowBox[{"u", ",", "y"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"unisamples", ",", "pair"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"exptab", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", "unisamples"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "n"}], "}"}]}], "]"}]}]], "Input",
