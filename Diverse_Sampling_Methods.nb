Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "As", " ", "can", " ", "be", " ", "seen", " ", "in", " ", "the", " ", 
     "plot", " ", "above"}], ",", " ", 
    RowBox[{
     RowBox[{
     "the", " ", "the", " ", "probability", " ", "of", " ", "of", " ", 
      "obtatining", " ", "a", " ", "value", " ", "for", " ", "x"}], " ", 
     "\[GreaterEqual]", 
     RowBox[{"2", " ", "is", " ", "relatively", " ", "low"}]}], ",", " ", 
    "however", ",", " ", 
    RowBox[{
    "even", " ", "if", " ", "x", " ", "increases", " ", "further", " ", "the",
      " ", "probaility", " ", "never", " ", "becomes", " ", 
     RowBox[{"zero", ".", " ", "Lets"}], " ", "define", " ", "the", " ", 
     "upperbound", " ", 
     RowBox[{"(", "up", ")"}], " ", "for", " ", "the", " ", "analysis"}], ",",
     " ", 
    RowBox[{
     RowBox[{"where", " ", "up"}], "=", 
     RowBox[{
      RowBox[{"f", "[", "x", "]"}], "==", "0.001"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"NSolve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], "\[Equal]", "0.001"}], ",", "x"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"up", "=", 
     RowBox[{"x", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.890747483695834*^9, 3.8907474865661097`*^9}, {
   3.8907476331800413`*^9, 3.8907476336599207`*^9}, {3.890747700317117*^9, 
