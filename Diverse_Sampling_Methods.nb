Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "acceptance", " ", "rejection", 
     " ", "criterion", " ", "for", " ", "this", " ", 
     RowBox[{"example", ".", "  ", "the"}], " ", "sample", " ", "y", " ", 
     "is", " ", "accepted", " ", "when", " ", "u"}], " ", "<", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "y", "]"}], "/", "c"}], "*", 
     RowBox[{
      RowBox[{"g", "[", "y", "]"}], "."}]}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"accept", "=", 
    RowBox[{"Cases", "[", 
     RowBox[{"Gammtab", ",", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"u_", ",", "y_"}], "}"}], "}"}], "/;", " ", 
       RowBox[{"u", "\[LessEqual]", 
        FractionBox[
         RowBox[{"f", "[", "y", "]"}], 
         RowBox[{"c", "*", 
          RowBox[{"g", "[", "y", "]"}]}]]}]}]}], " ", "]"}]}], 
   ";"}]}]], "Input",
