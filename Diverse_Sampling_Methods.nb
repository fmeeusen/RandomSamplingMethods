Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "As", " ", "can", " ", "be", " ", "seen", " ", "in", " ", "the", " ", 
     "plot", " ", "above"}], ",", " ", 
    RowBox[{
     RowBox[{
     "the", " ", "the", " ", "probability", " ", "of", " ", "of", " ", 
      "obtatining", " ", "a", " ", "value", " ", "for", " ", "x"}], " ", 
     "\[GreaterEqual]", " ", 
     RowBox[{"2", " ", "is", " ", "relatively", " ", "low"}]}], ",", " ", 
    "however", ",", " ", 
    RowBox[{
     RowBox[{
     "even", " ", "if", " ", "x", " ", "increases", " ", "further", " ", 
      "the", " ", "probaility", " ", "never", " ", "becomes", " ", 
      RowBox[{"zero", ".", " ", "Lets"}], " ", "define", " ", "the", " ", 
      "upperbound", " ", 
      RowBox[{"(", "up", ")"}], " ", "for", " ", "the", " ", "analysis", " ", 
      "where", " ", 
      RowBox[{"f", "[", "x", "]"}]}], "\[LessEqual]", "0.001"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"NSolve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], "\[Equal]", "0.001"}], ",", "x"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"up", "=", 
     RowBox[{"x", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.891250120874189*^9, 3.8912503373745413`*^9}, {
  3.8912503815455513`*^9, 3.8912504839424458`*^9}, {3.891250583844695*^9, 
  3.8912507870511928`*^9}, {3.891250818271267*^9, 3.8912508925988655`*^9}, {
  3.8912509228250947`*^9, 3.8912509627643723`*^9}, {3.891253434275282*^9, 
