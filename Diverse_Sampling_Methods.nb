Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "clears", " ", "all", " ", "definitions", " ", "and", " ", 
     "variables"}], ";", " ", 
