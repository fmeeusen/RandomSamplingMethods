Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "proposed", " ", "distribution", " ", "now", " ", "becomes", 
    " ", "the", " ", "normalized", " ", "uniform", " ", "distribution", " ", 
    "with", " ", "the", " ", "range", " ", "of", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", "up"}], ")"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"g", "[", "x_", "]"}], "=", 
    FractionBox["1", "up"]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.891250131905157*^9, 3.8912501421348257`*^9}, {
  3.891250967134389*^9, 3.8912510108496943`*^9}},
 CellLabel->
  "In[416]:=",ExpressionUUID->"0d1bc77b-e04c-4c2d-9624-3ba65e6c1ecd"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Now", " ", "compute", " ", "the", " ", "maximum", " ", "value", " ", 
     "of", " ", "this", " ", "distribution", " ", "and", " ", "set", " ", 
     "this", " ", "equal", " ", "to", " ", "the", " ", "value", " ", "for", 
     " ", "the", " ", "constant", " ", "c"}], ",", " ", 
    RowBox[{
    "to", " ", "make", " ", "sure", " ", "that", " ", "the", " ", "proposed", 
     " ", "distribution", " ", "completely", " ", "envelops", " ", 
     "\[IndentingNewLine]", "the", " ", "target", " ", 
     RowBox[{"distribution", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"c", "=", 
    RowBox[{"First", "[", 
     RowBox[{"FindMaximum", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"f", "[", "x", "]"}], 
        RowBox[{"g", "[", "x", "]"}]], ",", "x"}], "]"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.8910893921358223`*^9, 3.891089425957195*^9}, {
  3.8910902554632254`*^9, 3.8910903116371784`*^9}, {3.8911012926927977`*^9, 
  3.891101304493905*^9}, {3.891249218526844*^9, 3.8912492725369234`*^9}, {
  3.8912493255798674`*^9, 3.891249405961903*^9}, {3.8912510453778324`*^9, 
  3.8912510567022257`*^9}},
 CellLabel->
  "In[417]:=",ExpressionUUID->"305cf2b0-7614-4875-8d37-6a9f48073ab8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "just", " ", "an", " ", "empty", " ", "table", " ",
     "of", " ", "\"\<n\>\"", " ", "elements", " ", "to", " ", "store", " ", 
    "the", " ", "results"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Gammtab", "=", 
    RowBox[{"Table", "[", 
     RowBox[{",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8911014032126565`*^9, 3.8911014223507624`*^9}, 
   3.891101496067706*^9, {3.8912501087615423`*^9, 3.8912501132627525`*^9}},
