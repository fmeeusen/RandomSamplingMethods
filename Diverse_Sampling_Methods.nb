Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "defines", " ", "the", " ", "Box", " ", "Mueller", " ", 
    "transform"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"X", "=", 
     RowBox[{
      SqrtBox[
       RowBox[{
        RowBox[{"-", "2"}], 
        RowBox[{"Log", "[", "U1", "]"}]}]], " ", 
      RowBox[{"Cos", "[", 
       RowBox[{"2", "\[Pi]", " ", "U2"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Y", "=", 
     RowBox[{
      SqrtBox[
       RowBox[{
        RowBox[{"-", "2"}], 
        RowBox[{"Log", "[", "U1", "]"}]}]], " ", 
      RowBox[{"Sin", "[", 
       RowBox[{"2", "\[Pi]", " ", "U2"}], "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.8907575781949387`*^9, 3.8907576843978662`*^9}, {
  3.8907580151984215`*^9, 3.890758031826563*^9}, {3.890758079585529*^9, 
  3.8907580917002783`*^9}},
 CellLabel->
  "In[1286]:=",ExpressionUUID->"d2f92515-6d5c-4619-a45a-9103a0fd0b57"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "shows", " ", "the", " ", "sampled", " ", "standardized", " ",
     "normal", " ", "distribution", " ", "on", " ", "top", " ", "of", " ", 
    "the", " ", "analytical", " ", "normal", " ", "distribution"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"p1", "=", 
     RowBox[{"Histogram", "[", 
      RowBox[{"X", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "2"}], ",", "2", ",", 
         RowBox[{"1", "/", "5"}]}], "}"}], ",", "\"\<Probability\>\""}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p2", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", "5"], 
        RowBox[{"PDF", "[", 
         RowBox[{
          RowBox[{"NormalDistribution", "[", "]"}], ",", "x"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], ";"}]}]}]], "Input",
