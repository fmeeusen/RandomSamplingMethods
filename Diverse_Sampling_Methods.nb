Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "As", " ", "can", " ", "be", " ", "seen", " ", "in", " ", "the", " ", 
     "plot", " ", "above"}], ",", " ", 
    RowBox[{
     RowBox[{
     "the", " ", "the", " ", "probability", " ", "of", " ", "of", " ", 
      "obtatining", " ", "a", " ", "value", " ", "for", " ", "x"}], " ", 
     "\[GreaterEqual]", " ", 
     RowBox[{"10", " ", "is", " ", "relatively", " ", "low"}]}], ",", " ", 
    "however", ",", " ", 
    RowBox[{
     RowBox[{
     "even", " ", "if", " ", "x", " ", "increases", " ", "further", " ", 
      "the", " ", "probaility", " ", "never", " ", "becomes", " ", 
      RowBox[{"zero", ".", " ", "Lets"}], " ", "define", " ", "the", " ", 
      "upperbound", " ", 
      RowBox[{"(", "up", ")"}], " ", "for", " ", "the", " ", "analysis", " ", 
      "where", " ", 
      RowBox[{"f", "[", "x", "]"}]}], "\[LessEqual]", "0.001"}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"NSolve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "x", "]"}], "\[Equal]", "0.001"}], ",", "x"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"up", "=", 
     RowBox[{"x", "/.", 
      RowBox[{"sol", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.8912680214505367`*^9, 3.8912680603063784`*^9}, {
  3.891268380658654*^9, 3.8912683862135787`*^9}, {3.891268573665805*^9, 
  3.891268607991584*^9}},
 CellLabel->
  "In[839]:=",ExpressionUUID->"8261b3be-e89c-47d6-9759-b9bbb41fe907"],

Cell[BoxData[
 TemplateBox[{
  "NSolve", "ratnz", 
   "\"NSolve was unable to solve the system with inexact coefficients. The \
answer was obtained by solving a corresponding exact system and numericizing \
the result.\"", 2, 839, 135, 34247833420041001868, "Local"},
  "MessageTemplate"]], "Message", "MSG",
 CellChangeTimes->{{3.8912680395751286`*^9, 3.8912680606221237`*^9}, 
   3.891268337952112*^9, {3.8912683812321463`*^9, 3.8912683866574087`*^9}, {
   3.8912685749584165`*^9, 3.89126860824409*^9}, 3.891268946094388*^9},
 CellLabel->
  "During evaluation of \
In[839]:=",ExpressionUUID->"43abd5ad-f1f5-4b39-a8be-4917c4912d94"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "proposed", " ", "distribution", " ", "now", " ", "becomes", 
    " ", "the", " ", "normalized", " ", "uniform", " ", "distribution", " ", 
    "with", " ", "the", " ", "range", " ", "of", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", "up"}], ")"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"g", "[", "x_", "]"}], "=", 
    FractionBox["1", 
     RowBox[{"up", "-", "\[Theta]"}]]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8912689144041834`*^9, 3.8912689183265343`*^9}},
 CellLabel->
  "In[841]:=",ExpressionUUID->"9963ce46-8ce6-40a3-9508-98f9446e9b86"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Now", " ", "compute", " ", "the", " ", "maximum", " ", "value", " ", 
     "of", " ", "this", " ", "distribution", " ", "and", " ", "set", " ", 
     "this", " ", "equal", " ", "to", " ", "the", " ", "value", " ", "for", 
     " ", "the", " ", "constant", " ", "c"}], ",", " ", 
    RowBox[{
    "to", " ", "make", " ", "sure", " ", "that", " ", "the", " ", "proposed", 
     " ", "distribution", " ", "completely", " ", "envelops", " ", 
     "\[IndentingNewLine]", "the", " ", "target", " ", 
     RowBox[{"distribution", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"c", "=", 
    RowBox[{"First", "[", 
     RowBox[{"FindMaximum", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"f", "[", "x", "]"}], 
        RowBox[{"g", "[", "x", "]"}]], ",", "x"}], "]"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.8912681338726044`*^9, 3.8912681824304314`*^9}, {
  3.891269053857217*^9, 3.891269077416384*^9}, {3.8912694200368834`*^9, 
  3.8912694246876135`*^9}, {3.891269497332596*^9, 3.8912694985499263`*^9}},
 CellLabel->
  "In[854]:=",ExpressionUUID->"66439345-e0ed-46e8-8bc7-81acb3eb7eb6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "just", " ", "an", " ", "empty", " ", "table", " ",
     "of", " ", "\"\<n\>\"", " ", "elements", " ", "to", " ", "store", " ", 
    "the", " ", "results"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Weibulltab", "=", 
    RowBox[{"Table", "[", 
     RowBox[{",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.891268206977393*^9, 3.8912682086792927`*^9}},
 CellLabel->
  "In[843]:=",ExpressionUUID->"f1864684-c506-4d2e-81e3-c6aba034210c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "generates", " ", "samples", " ", "from", " ", "the", " ", 
    "Uniform", " ", "Distribution", " ", "with", " ", "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "1"}], ")"}], " ", 
    RowBox[{"(", "u", ")"}], " ", "and", " ", "an", " ", "observation", " ", 
    "from", " ", "the", " ", "Uniform", " ", "Distribution", " ", "with", " ",
     "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "up"}], ")"}], " ", 
    RowBox[{
     RowBox[{"(", "y", ")"}], ".", " ", "Both"}], " ", "samples", " ", "are", 
    " ", "stored", "  ", "as", " ", "a", " ", "pair", " ", "in", " ", "the", 
    " ", "previously", " ", "defined", " ", 
    RowBox[{"table", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"unisamples", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"u", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], "]"}]}], " ", ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "up"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"pair", "=", 
      RowBox[{"{", 
       RowBox[{"u", ",", "y"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"unisamples", ",", "pair"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Weibulltab", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", "unisamples"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "n"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.891268264224923*^9, 3.891268285778414*^9}, {
  3.8912684022339954`*^9, 3.8912684030521526`*^9}, {3.8912689284556785`*^9, 
  3.8912689310086403`*^9}},
 CellLabel->
  "In[844]:=",ExpressionUUID->"69575177-95d3-45cb-9686-9d6d76135cb6"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "acceptance", " ", "rejection", 
     " ", "criterion", " ", "for", " ", "this", " ", 
     RowBox[{"example", ".", "  ", "the"}], " ", "sample", " ", "y", " ", 
     "is", " ", "accepted", " ", "when", " ", "u"}], " ", "<", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "y", "]"}], "/", "c"}], "*", 
     RowBox[{
      RowBox[{"g", "[", "y", "]"}], "."}]}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"accept", "=", 
     RowBox[{"Cases", "[", 
      RowBox[{"Weibulltab", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"u_", ",", "y_"}], "}"}], "}"}], "/;", " ", 
        RowBox[{"u", "\[LessEqual]", 
         FractionBox[
          RowBox[{"f", "[", "y", "]"}], 
          RowBox[{"c", "*", 
           RowBox[{"g", "[", "y", "]"}]}]]}]}]}], " ", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"accepted", " ", "=", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"accept", ",", "1"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.891268306132304*^9, 3.891268313269058*^9}},
 CellLabel->
  "In[845]:=",ExpressionUUID->"913876e1-9723-4dce-9ab1-d837e3e0b9d6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "shows", " ", "the", " ", "generated", " ", "sample", " ", 
    "against", " ", "the", " ", "analtical", " ", "PDF"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"p1", "=", 
     RowBox[{"Histogram", "[", 
      RowBox[{"accepted", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "up", ",", 
         FractionBox["1", "5"]}], "}"}], ",", "Probability"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p2", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", "5"], 
        RowBox[{"f", "[", "x", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "up"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"p1", ",", "p2"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.8912684165919886`*^9, 3.891268425483346*^9}},
 CellLabel->
  "In[847]:=",ExpressionUUID->"87c76312-f03a-44fd-a3b6-5b5526a74937"],

