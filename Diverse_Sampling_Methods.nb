Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "this", " ", "defines", " ", "the", " ", "number", " ", "of", " ", 
     "observations", " ", 
     RowBox[{"(", "n", ")"}], " ", "and", " ", "the", " ", "minimum", " ", 
     RowBox[{"(", "a", ")"}]}], ",", " ", 
    RowBox[{"mode", " ", 
     RowBox[{"(", "b", ")"}], " ", "and", " ", "maximum", " ", "value", " ", 
     "for", " ", "the", " ", "triangular", " ", 
     RowBox[{"distribution", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{"5", "*", 
       SuperscriptBox["10", "4"]}]}], ",", 
     RowBox[{"a", "=", "1"}], ",", 
     RowBox[{"b", "=", "2"}], ",", 
     RowBox[{"c", "=", "3"}]}], "}"}], ";"}]}]], "Input",
 CellChangeTimes->{{3.890577695874801*^9, 3.8905777482351894`*^9}, {
  3.8905779757528505`*^9, 3.890577996375656*^9}, {3.891272947832795*^9, 
  3.8912730271553526`*^9}, {3.8912732839482694`*^9, 3.8912732858352475`*^9}, {
  3.891273358424694*^9, 3.891273370500269*^9}, {3.891273960263918*^9, 
  3.891273960964568*^9}, {3.891274038864013*^9, 
  3.8912740457919416`*^9}},ExpressionUUID->"5fc19e04-26ae-492b-a717-\
9a912ad17542"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "takes", " ", "a", " ", "sample", " ", "of", " ", "the", " ", 
    "uniform", " ", 
    RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"U", "=", 
    RowBox[{"RandomReal", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], ",", "n"}], "]"}]}], ";"}]}]], "Input",\
ExpressionUUID->"190e2e87-d810-4939-be8e-245e8dad196c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "converts", " ", "the", " ", "sample", " ", "of", " ", "the", 
    " ", "uniform", " ", "distribution", " ", "to", " ", "a", " ", "sample", 
    " ", "of", " ", "the", " ", "triangular", " ", 
    RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"f", "[", "u_", "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           SqrtBox[
            RowBox[{"u", 
             RowBox[{"(", 
              RowBox[{"c", "-", "a"}], ")"}], 
             RowBox[{"(", 
              RowBox[{"b", "-", "a"}], ")"}]}]], "+", "a"}], ",", 
          RowBox[{"0", "\[LessEqual]", "u", "<", 
           FractionBox[
            RowBox[{"b", "-", "a"}], 
            RowBox[{"c", "-", "a"}]]}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"c", "-", 
           SqrtBox[
            RowBox[{
             RowBox[{"(", 
              RowBox[{"c", "-", "a"}], ")"}], 
             RowBox[{"(", 
              RowBox[{"c", "-", "b"}], ")"}], 
             RowBox[{"(", 
              RowBox[{"1", "-", "u"}], ")"}]}]]}], ",", 
          RowBox[{
           FractionBox[
            RowBox[{"b", "-", "a"}], 
            RowBox[{"c", "-", "a"}]], "\[LessEqual]", "u", "<", "1"}]}], 
         "}"}]}], "}"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"triangular", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", "#", "]"}], "&"}], ",", "U"}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.891273068886716*^9, 3.8912731796402617`*^9}, {
   3.8912732936016455`*^9, 3.891273293665266*^9}, {3.8912733469099035`*^9, 
   3.891273434122414*^9}, {3.89127348430262*^9, 3.891273507340858*^9}, {
   3.891273663987216*^9, 3.8912737119210396`*^9}, {3.891273741987508*^9, 
   3.8912738140588365`*^9}, 3.891273855014882*^9, {3.891273923358116*^9, 
   3.891273929441434*^9}, {3.891274027016493*^9, 
   3.8912740333557873`*^9}},ExpressionUUID->"bfacc763-c3d3-423f-bd35-\
546f00607473"],

