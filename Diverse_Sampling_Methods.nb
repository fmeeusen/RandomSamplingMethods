Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "plots", " ", "the", " ", "sampled", " ", "Exponential", " ", 
    "distribution", " ", "against", " ", "the", " ", "analytical", " ", 
    RowBox[{"PDF", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"p1", "=", 
     RowBox[{"Histogram", "[", 
      RowBox[{"exp", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "4", ",", 
         RowBox[{"1", "/", "20"}]}], "}"}], ",", "\"\<Probability\>\"", ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p2", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "20"}], 
        RowBox[{"PDF", "[", 
         RowBox[{
          RowBox[{"ExponentialDistribution", "[", "\[Lambda]", "]"}], ",", 
          "x"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "3.5"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"p1", ",", "p2"}], "]"}]}]}]], "Input",
