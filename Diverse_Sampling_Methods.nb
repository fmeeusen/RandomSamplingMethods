Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "generates", " ", "two", " ", "samples", " ", "of", " ", 
     "the", " ", "uniform", " ", "distributions", " ", "of", " ", "length", 
     " ", "a", " ", "and", " ", 
     RowBox[{"b", "."}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"u1", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", "a", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"u2", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", "b", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "This", " ", "transforms", " ", "the", " ", "uniform", " ", 
       "distributions", " ", "into", " ", "the", " ", "ones", " ", "of", " ", 
       "the", " ", "Exponential", " ", "distributions", " ", "with", " ", 
       "rate", " ", "parameter", " ", "\[Lambda]"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"x", "=", 
      FractionBox[
       RowBox[{"-", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", "u1"}], "]"}]}], "\[Lambda]"]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      FractionBox[
       RowBox[{"-", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", "u2"}], "]"}]}], "\[Lambda]"]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "This", " ", "transforms", " ", "the", " ", "Exponetial", " ", 
        "distributions", " ", "into", " ", "Gamma", " ", "distributions"}], 
       ",", " ", 
       RowBox[{"where", " ", 
        RowBox[{"xx", "~", "Gamma"}], 
        RowBox[{"(", 
         RowBox[{"a", ",", "\[Lambda]"}], ")"}], "and", " ", 
        RowBox[{"yy", "~", "Gamma"}], 
        RowBox[{"(", 
         RowBox[{"a", ",", "\[Lambda]"}], ")"}]}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"xx", "=", 
      RowBox[{"Total", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"yy", "=", 
      RowBox[{"Total", "[", "y", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "This", " ", "transforms", " ", "the", " ", "Gamma", " ", 
       "distributions", " ", "into", " ", "a", " ", "Beta", " ", 
       "distribution", " ", "with", " ", "parameters", " ", 
       RowBox[{"(", 
        RowBox[{"a", ",", "b"}], ")"}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"ww", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", 
      FractionBox["xx", 
       RowBox[{"xx", "+", "yy"}]]}], ";"}], "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "nobs"}], "}"}]}], "]"}], ";"}]], "Input",
 CellChangeTimes->{{3.891076699305402*^9, 3.8910768829135466`*^9}, {
  3.891077112694761*^9, 
  3.891077295274824*^9}},ExpressionUUID->"bf10e9af-3de3-4e17-8783-\
04f63bc3e86e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "plots", " ", "the", " ", "sampled", " ", "Beta", " ", 
    "distribution", " ", "against", " ", "the", " ", "analytical", " ", 
    RowBox[{"PDF", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"p1", "=", 
     RowBox[{"Histogram", "[", 
      RowBox[{"ww", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1", ",", 
         FractionBox["1", "20"]}], "}"}], ",", "\"\<Probability\>\""}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p2", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", "20"], 
        RowBox[{"PDF", "[", 
         RowBox[{
          RowBox[{"BetaDistribution", "[", 
           RowBox[{"a", ",", "b"}], "]"}], ",", "x"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "25"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"p1", ",", "p2"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.8909249159895687`*^9, 3.890924916627308*^9}, {
