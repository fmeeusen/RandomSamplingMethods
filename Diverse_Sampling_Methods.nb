Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "generates", " ", "a", " ", "sample", " ", "of", " ", "size",
      " ", "n", " ", "from", " ", "the", " ", "Bernoulli", " ", 
     RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"U", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", "n"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"bernsample", "=", 
      RowBox[{
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"#", "<", "p"}], "&"}], ",", "U"}], "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"True", "\[Rule]", "1"}], ",", 
         RowBox[{"False", "\[Rule]", "0"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "This", " ", "defines", " ", "the", " ", "first", " ", "index", " ", 
       "when", " ", "the", " ", "outcome", " ", "of", " ", "the", " ", 
       "Bernoulli", " ", "trial", " ", "is", " ", "1"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"first1", "=", 
      RowBox[{"First", "[", 
       RowBox[{"Flatten", "[", 
        RowBox[{"Position", "[", 
         RowBox[{"bernsample", ",", "1", ",", "1", ",", "1"}], "]"}], "]"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
        "This", " ", "takes", " ", "and", " ", "stores", " ", "the", " ", 
         "first", " ", "index"}], " ", "-", "1"}], " ", ":"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"first1", "-", "1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"GeomDist", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", "y"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "nrepeats"}], "}"}]}], "]"}], 
