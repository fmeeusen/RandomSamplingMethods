  "In[400]:=",ExpressionUUID->"25c28e42-45c0-43f1-8998-1b1257c1b08e"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
   "This", " ", "defines", " ", "the", " ", "number", " ", "of", " ", 
    "observations", " ", "n"}], ",", " ", 
   RowBox[{"and", " ", "the", " ", "value", " ", "for", " ", "\[Lambda]"}]}], 
  " ", "*)"}]], "Input",
 CellChangeTimes->{{3.890930485523079*^9, 
  3.8909305169647703`*^9}},ExpressionUUID->"96b7fef7-94a4-478c-921d-\
b9573253ffb5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"{", 
   RowBox[{
    RowBox[{"n", "=", 
     SuperscriptBox["10", "4"]}], ",", 
    RowBox[{"\[Lambda]", "=", "3"}]}], "}"}], ";"}]], "Input",
 CellChangeTimes->{{3.8909305216061583`*^9, 3.8909305423030577`*^9}, {
  3.890978304953272*^9, 3.8909783147997737`*^9}},
 CellLabel->
  "In[809]:=",ExpressionUUID->"ea4b9f4b-10e1-41d5-8360-3a34d156395b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "takes", " ", "a", " ", "sample", " ", "of", " ", "n", " ", 
    "observations", " ", "from", " ", "the", " ", "uniform", " ", 
    RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"u", "=", 
    RowBox[{"RandomReal", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], ",", "n"}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8905839153765416`*^9, 3.89058393555796*^9}, 
   3.8906711900750585`*^9, {3.8909304279578032`*^9, 3.890930480253524*^9}},
 CellLabel->
  "In[804]:=",ExpressionUUID->"eeaede00-b3da-4185-bc8b-d70b36297797"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "transforms", " ", "the", " ", "sampled", " ", "uniform", " ",
     "distribution", " ", "into", " ", "a", " ", "sample", " ", "of", " ", 
    "the", " ", "Exponential", " ", "distribution"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"exp", "=", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"Log", "[", 
       RowBox[{"1", "-", "u"}], "]"}], "\[Lambda]"]}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8905796472462063`*^9, 3.8905796928869357`*^9}, {
  3.8905803712701073`*^9, 3.890580374853962*^9}, {3.8905804724859858`*^9, 
  3.8905804923678775`*^9}, {3.890580575502824*^9, 3.890580578933983*^9}, {
  3.8905806491021914`*^9, 3.890580649211153*^9}, {3.8905810924304633`*^9, 
  3.8905811062919717`*^9}, {3.890583939988223*^9, 3.89058396708675*^9}, {
  3.8909304361366444`*^9, 3.890930449357727*^9}, {3.89093053690699*^9, 
  3.8909305866603107`*^9}},
