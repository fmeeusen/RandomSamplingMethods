     RowBox[{"exptab", ",", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"u_", ",", "y_"}], "}"}], "}"}], "/;", " ", 
       RowBox[{"u", "\[LessEqual]", 
        FractionBox[
         RowBox[{"f", "[", "y", "]"}], 
         RowBox[{"c", "*", 
          RowBox[{"g", "[", "y", "]"}]}]]}]}]}], " ", "]"}]}], 
   ";"}]}]], "Input",
