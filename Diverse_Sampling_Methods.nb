Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "takes", " ", "a", " ", "sample", " ", "of", " ", "n", " ", 
     "observations", " ", "from", " ", "the", " ", "uniform", " ", 
     RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"u", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "1"}], "}"}], ",", 
        RowBox[{"{", "n", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "This", " ", "transforms", " ", "the", " ", "Uniform", " ", 
       "distribution", " ", "into", " ", "a", " ", "Exponetial", " ", 
       "distribution", " ", "with", " ", "rate", " ", "parameter", " ", 
       RowBox[{"\[Lambda]", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"x", "=", 
      FractionBox[
       RowBox[{"-", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", "u"}], "]"}]}], "\[Lambda]"]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
       RowBox[{
       "This", " ", "transforms", " ", "the", " ", "Exponetial", " ", 
        "distribution", " ", "into", " ", "a", " ", "Gamma", " ", 
        "distribution", " ", "with", " ", "shape", " ", "and", " ", "rate", 
        " ", "parameter", " ", "n"}], ",", "\[Lambda]"}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"Total", "[", "x", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"yy", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", "y"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "nrepeats"}], "}"}]}], "]"}], 
  ";"}]], "Input",
