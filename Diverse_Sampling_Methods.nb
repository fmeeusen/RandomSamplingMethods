  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "plots", " ", "the", " ", "sampled", " ", "Triangular", " ", 
    "distribution", " ", "against", " ", "the", " ", "analytical", " ", 
    RowBox[{"PDF", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"p1", "=", 
     RowBox[{"Histogram", "[", 
