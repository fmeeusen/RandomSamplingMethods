Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
     "The", " ", "Beta", " ", "distribution", " ", "is", " ", "only", " ", 
      "defined", " ", "for", " ", "defined", " ", "for", " ", "0"}], "<", "x",
      "<", 
     RowBox[{"1.", " ", "Therefore"}]}], ",", " ", 
    RowBox[{
    "the", " ", "proposed", " ", "distrbibution", " ", "is", " ", "just", " ",
      "the", " ", "normal", " ", "uniform", " ", "distribution"}]}], " ", 
   "*)"}], " ", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"g", "[", "x_", "]"}], "=", "1"}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8912538198762336`*^9, 3.8912538832244186`*^9}, {
  3.8912540578854237`*^9, 3.8912540580585785`*^9}},
 CellLabel->
  "In[452]:=",ExpressionUUID->"58ebcb28-e090-4c33-b3c9-fbcdbbfef8d5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "value", " ", "for", " ", "c", " ", "simply", " ", "becomes", 
    " ", "the", " ", "maximum", " ", "value", " ", "of", " ", "the", " ", 
    "Beta", " ", "distribution"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"c", "=", 
    RowBox[{"First", "[", 
     RowBox[{"FindMaximum", "[", 
      RowBox[{
       RowBox[{"f", "[", "x", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "1"}], "}"}]}], "]"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.8912539038826523`*^9, 3.89125392331252*^9}, {
   3.8912540469397726`*^9, 3.891254047114267*^9}, 3.891254885964757*^9, {
   3.891255049074558*^9, 3.8912552183590784`*^9}},
 CellLabel->
  "In[453]:=",ExpressionUUID->"d74e500b-594b-4e27-9b20-7e91ed303d85"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "just", " ", "an", " ", "empty", " ", "table", " ",
     "of", " ", "\"\<n\>\"", " ", "elements", " ", "to", " ", "store", " ", 
    "the", " ", "results"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Betatab", "=", 
    RowBox[{"Table", "[", 
     RowBox[{",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8912540659411526`*^9, 3.8912540662418375`*^9}},
 CellLabel->
  "In[454]:=",ExpressionUUID->"43bea756-ed84-4b63-8a2e-ad6a1188d515"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "generates", " ", "samples", " ", "from", " ", "the", " ", 
    "Uniform", " ", "Distribution", " ", "with", " ", "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "1"}], ")"}], " ", 
    RowBox[{"(", "u", ")"}], " ", "and", " ", "an", " ", "observation", " ", 
    "from", " ", "the", " ", "Uniform", " ", "Distribution", " ", "with", " ",
     "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "1"}], ")"}], " ", 
    RowBox[{
     RowBox[{"(", "y", ")"}], ".", " ", "Both"}], " ", "samples", " ", "are", 
    " ", "stored", "  ", "as", " ", "a", " ", "pair", " ", "in", " ", "the", 
    " ", "previously", " ", "defined", " ", 
    RowBox[{"table", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"unisamples", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"u", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], "]"}]}], " ", ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pair", "=", 
      RowBox[{"{", 
       RowBox[{"u", ",", "y"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"unisamples", ",", "pair"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Betatab", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", "unisamples"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "n"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.8912541083295774`*^9, 3.8912541157903147`*^9}, {
  3.8912541790086994`*^9, 3.891254179324532*^9}},
 CellLabel->
  "In[455]:=",ExpressionUUID->"8861029e-5be1-461d-8e1e-933417611a78"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "acceptance", " ", "rejection", 
     " ", "criterion", " ", "for", " ", "this", " ", 
     RowBox[{"example", ".", "  ", "the"}], " ", "sample", " ", "y", " ", 
     "is", " ", "accepted", " ", "when", " ", "u"}], " ", "<", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "y", "]"}], "/", "c"}], "*", 
     RowBox[{
      RowBox[{"g", "[", "y", "]"}], "."}]}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"accept", "=", 
     RowBox[{"Cases", "[", 
      RowBox[{"Betatab", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"u_", ",", "y_"}], "}"}], "}"}], "/;", " ", 
        RowBox[{"u", "\[LessEqual]", 
         FractionBox[
          RowBox[{"f", "[", "y", "]"}], 
          RowBox[{"c", "*", 
           RowBox[{"g", "[", "y", "]"}]}]]}]}]}], " ", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"accepted", " ", "=", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"accept", ",", "1"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.891254224208724*^9, 3.8912542345505743`*^9}, {
  3.8912542765272517`*^9, 3.8912542781198454`*^9}},
