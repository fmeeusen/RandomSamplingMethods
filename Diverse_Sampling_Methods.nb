Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"The", " ", "proposed", " ", "PDF"}], ",", " ", 
    RowBox[{"g", 
     RowBox[{"(", "x", ")"}]}], ",", " ", 
    RowBox[{
    "is", " ", "given", " ", "as", " ", "the", " ", "normalized", " ", 
     "Uniform", " ", "distribution", " ", "from", " ", "0", " ", "to", " ", 
     "up"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"g", "[", "x_", "]"}], "=", 
    FractionBox["1", "up"]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8912630595978856`*^9, 3.8912631217170067`*^9}, {
  3.8912632849189177`*^9, 3.891263285234564*^9}},
 CellLabel->
  "In[721]:=",ExpressionUUID->"a8675883-d00c-486f-8e62-a38c39753fb3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"The", " ", "value", " ", "for", " ", "c", " ", "is", " ", 
    RowBox[{"Max", "[", 
     FractionBox[
      RowBox[{"f", "[", "x", "]"}], 
      RowBox[{"g", "[", "x", "]"}]], "]"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"c", "=", 
    RowBox[{"First", "[", 
     RowBox[{"FindMaximum", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"f", "[", "x", "]"}], 
        RowBox[{"g", "[", "x", "]"}]], ",", "x"}], "]"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.891263146792483*^9, 3.8912631681219063`*^9}, {
  3.891263226956992*^9, 3.891263247505618*^9}, {3.8912633077082915`*^9, 
  3.891263331370065*^9}, {3.891263374052663*^9, 3.891263404683008*^9}, {
  3.891263460976303*^9, 3.8912635247061033`*^9}, {3.891263566885061*^9, 
  3.8912635740267467`*^9}},
 CellLabel->
  "In[734]:=",ExpressionUUID->"06ab8fb0-2da8-4292-a778-5b215caeea82"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "just", " ", "an", " ", "empty", " ", "table", " ",
     "of", " ", "\"\<n\>\"", " ", "elements", " ", "to", " ", "store", " ", 
    "the", " ", "results"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Polynomtab", "=", 
    RowBox[{"Table", "[", 
     RowBox[{",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8912637338493156`*^9, 3.891263738676304*^9}},
 CellLabel->
  "In[735]:=",ExpressionUUID->"5dff4842-7661-4282-99c3-ebef4cd41c66"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "generates", " ", "samples", " ", "from", " ", "the", " ", 
    "Uniform", " ", "Distribution", " ", "with", " ", "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "1"}], ")"}], " ", 
    RowBox[{"(", "u", ")"}], " ", "and", " ", "an", " ", "observation", " ", 
    "from", " ", "the", " ", "Uniform", " ", "Distribution", " ", "with", " ",
     "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "1"}], ")"}], " ", 
    RowBox[{
     RowBox[{"(", "y", ")"}], ".", " ", "Both"}], " ", "samples", " ", "are", 
    " ", "stored", "  ", "as", " ", "a", " ", "pair", " ", "in", " ", "the", 
    " ", "previously", " ", "defined", " ", 
    RowBox[{"table", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"unisamples", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"u", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], "]"}]}], " ", ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "up"}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pair", "=", 
      RowBox[{"{", 
       RowBox[{"u", ",", "y"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"unisamples", ",", "pair"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Polynomtab", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", "unisamples"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "n"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.891263763588231*^9, 3.8912638041323805`*^9}},
 CellLabel->
  "In[736]:=",ExpressionUUID->"50f2e082-848e-4275-9588-f18dc23a5665"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "acceptance", " ", "rejection", 
     " ", "criterion", " ", "for", " ", "this", " ", 
     RowBox[{"example", ".", "  ", "the"}], " ", "sample", " ", "y", " ", 
     "is", " ", "accepted", " ", "when", " ", "u"}], " ", "<", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"f", "[", "y", "]"}], "/", "c"}], "*", 
     RowBox[{
      RowBox[{"g", "[", "y", "]"}], "."}]}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"accept", "=", 
     RowBox[{"Cases", "[", 
      RowBox[{"Polynomtab", ",", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"{", 
          RowBox[{"u_", ",", "y_"}], "}"}], "}"}], "/;", " ", 
        RowBox[{"u", "\[LessEqual]", 
         FractionBox[
          RowBox[{"f", "[", "y", "]"}], 
          RowBox[{"c", "*", 
           RowBox[{"g", "[", "y", "]"}]}]]}]}]}], " ", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"accepted", " ", "=", 
     RowBox[{
      RowBox[{"Flatten", "[", 
       RowBox[{"accept", ",", "1"}], "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"All", ",", "2"}], "]"}], "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.8912638526585636`*^9, 3.891263857547434*^9}},
 CellLabel->
  "In[739]:=",ExpressionUUID->"43cc7ce5-0b29-4080-a1de-01f807c0c373"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "shows", " ", "the", " ", "generated", " ", "sample", " ", 
    "against", " ", "the", " ", "analtical", " ", "PDF"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"p1", "=", 
     RowBox[{"Histogram", "[", 
      RowBox[{"accepted", ",", 
       RowBox[{"{", 
        RowBox[{"0", ",", "up", ",", 
         FractionBox["1", "5"]}], "}"}], ",", "Probability"}], "]"}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"p2", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{
        FractionBox["1", "5"], 
        RowBox[{"f", "[", "x", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "0", ",", "up"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"p1", ",", "p2"}], "]"}]}]}]], "Input",
