      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "5"}], 
        RowBox[{"PDF", "[", 
         RowBox[{
          RowBox[{"TriangularDistribution", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"a", ",", "c"}], "}"}], ",", "b"}], "]"}], ",", "x"}], 
         "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "a", ",", "c"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Show", "[", 
    RowBox[{"p1", ",", "p2"}], "]"}]}]}]], "Input",
