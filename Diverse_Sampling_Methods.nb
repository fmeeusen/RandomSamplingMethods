    RowBox[{"the", " ", "sample", " ", "size"}], ",", " ", 
    RowBox[{
    "the", " ", "value", " ", "for", " ", "\[Lambda]", " ", "and", " ", "the",
      " ", "number", " ", "of", " ", "times", " ", "the", " ", "experiment", 
     " ", "is", " ", "repeated", " ", 
     RowBox[{"respecitvely", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", "=", "25"}], ",", 
      RowBox[{"\[Lambda]", "=", "2"}], ",", 
      RowBox[{"nrepeats", "=", 
       SuperscriptBox["10", "4"]}]}], "}"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Empty", " ", "tables", " ", "for", " ", "storing", " ", 
