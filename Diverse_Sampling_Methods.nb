Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "generates", " ", "two", "  ", "uniform", " ", 
     "distributions", " ", "called", " ", "U1", " ", "and", " ", "U2"}], ",", 
    " ", 
    RowBox[{"with", " ", "sample", " ", "size", " ", 
     RowBox[{"nsize", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"nsize", "=", 
     SuperscriptBox["10", "6"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"U1", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", "nsize"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"U2", "=", 
     RowBox[{"RandomReal", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", "nsize"}], "]"}]}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.8907573104757857`*^9, 3.8907573736648893`*^9}, {
  3.8907578485809298`*^9, 3.8907578814889574`*^9}, {3.890758045725491*^9, 
  3.8907580763112917`*^9}, {3.8909700355992217`*^9, 3.8909700358290896`*^9}, {
  3.8909705057219176`*^9, 3.89097050647987*^9}, {3.890985955224304*^9, 
  3.890985955956025*^9}, {3.890986000856106*^9, 3.8909860010277205`*^9}},
