Cell[CellGroupData[{

Cell["Accept and Reject Sampling (ARM)", "Chapter",
 CellChangeTimes->{{3.8905547984973345`*^9, 
  3.8905548099869423`*^9}},ExpressionUUID->"3acdcdef-d3ea-43d0-8db4-\
23d9a9fafc57"],

Cell[CellGroupData[{

Cell["Geometric", "Section",
 CellChangeTimes->{{3.890555072890252*^9, 3.890555101199038*^9}, 
   3.890801669530589*^9, {3.8909641506372385`*^9, 
   3.8909641550267735`*^9}},ExpressionUUID->"80b5b675-9169-4f59-bcc3-\
0b87da3098c1"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "clears", " ", "all", " ", "definitions", " ", "and", " ", 
     "variables"}], ";", " ", 
    RowBox[{"Quit", " ", "Kernel"}]}], " ", "*)"}], "\n", 
  RowBox[{"ClearAll", "[", 
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{"Context", "[", "]"}], "<>", "\"\<*\>\""}], "]"}], 
   "]"}]}]], "Input",
 CellLabel->
  "In[231]:=",ExpressionUUID->"ada67182-612e-4938-bb79-223c00157116"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "defines", " ", "the", " ", "sample", " ", "size", " ", "n", 
    " ", "and", " ", "the", " ", "probabiity", " ", "for", " ", "success"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{"5", "*", 
       SuperscriptBox["10", "4"]}]}], ",", 
     RowBox[{"p", "=", 
      FractionBox["1", "3"]}]}], "}"}], ";"}]}]], "Input",
 CellChangeTimes->{{3.890964176907237*^9, 3.8909642372526875`*^9}},
 CellLabel->
  "In[232]:=",ExpressionUUID->"ea5d1bd8-bb5d-4416-bd2c-fbb90ddc8ec5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "defines", " ", "an", " ", "empty", " ", "table", " ", "with",
     " ", "intially", " ", "0", " ", "rows", " ", "and", " ", 
    RowBox[{"columns", ".", " ", "It"}], " ", "will", " ", "be", " ", "used", 
    " ", "to", " ", "store", " ", "the", " ", 
    RowBox[{"results", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Geom", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"u", "=", 
        RowBox[{"RandomReal", "[", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"i", "=", "0"}], ";", "\[IndentingNewLine]", 
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"u", ">=", " ", "p"}], ",", " ", 
         RowBox[{
          RowBox[{"u", "=", 
           RowBox[{"RandomReal", "[", 
            RowBox[{"{", 
             RowBox[{"0", ",", "1"}], "}"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"i", "++"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{
         "In", " ", "the", " ", "While", " ", "loop", " ", "a", " ", "sample",
           " ", "of", " ", "the", " ", "uniform", " ", "is", " ", "generated",
           " ", "and", " ", "it", " ", "is", " ", "checked", " ", "whether", 
          " ", "or", " ", "not", " ", "this", " ", "sample", " ", "meets", 
          " ", "our", " ", "acceptance", " ", 
          RowBox[{"criterion", ":", " ", 
           RowBox[{"u", " ", "\[GreaterEqual]", " ", 
            RowBox[{
             RowBox[{"p", ".", " ", "When"}], " ", "this", " ", 
             "happens"}]}]}]}], ",", " ", 
         RowBox[{"the", " ", "number", " ", "of", " ", "iterations", " ", 
          RowBox[{"(", "N", ")"}]}], ",", " ", 
         RowBox[{
         "that", " ", "it", " ", "took", " ", "to", " ", "get", " ", "to", 
          " ", "the", " ", "first", " ", "sucess", " ", "is", " ", "accepted",
           " ", "as", " ", "a", " ", "sample", " ", "and", " ", "is", " ", 
          "stored", " ", "in", " ", "the", " ", 
          RowBox[{"table", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
       "i"}], ",", " ", "\[IndentingNewLine]", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.890655414350915*^9, 3.8906554263786116`*^9}, {
   3.890655462925608*^9, 3.8906554637245593`*^9}, {3.890655538687048*^9, 
   3.890655540887158*^9}, 3.8906564641882653`*^9, {3.8906565007854567`*^9, 
   3.890656501187672*^9}, {3.8906586345781584`*^9, 3.890658642542807*^9}, {
   3.890658691279567*^9, 3.890658692083597*^9}, {3.8907504513309445`*^9, 
   3.890750467163468*^9}, 3.8909645211952505`*^9, {3.890964901421879*^9, 
   3.8909650733873425`*^9}, {3.8909652344535275`*^9, 3.890965412980988*^9}, {
   3.890965451144902*^9, 3.8909654703988523`*^9}},
 CellLabel->
  "In[233]:=",ExpressionUUID->"ef49a748-be22-46e2-b023-796790cec397"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"p1", "=", 
   RowBox[{"Histogram", "[", 
    RowBox[{"Geom", ",", "Automatic", ",", "\"\<Probability\>\""}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p2", "=", 
   RowBox[{"DiscretePlot", "[", 
    RowBox[{
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"GeometricDistribution", "[", "p", "]"}], ",", "x"}], "]"}], 
