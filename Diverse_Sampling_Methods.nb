Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "generates", " ", "samples", " ", "from", " ", "the", " ", 
    "Uniform", " ", "Distribution", " ", "with", " ", "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "1"}], ")"}], " ", 
    RowBox[{"(", "u", ")"}], " ", "and", " ", "an", " ", "observation", " ", 
    "from", " ", "the", " ", "Uniform", " ", "Distribution", " ", "with", " ",
     "range", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", " ", "up"}], ")"}], " ", 
    RowBox[{
     RowBox[{"(", "y", ")"}], ".", " ", "Both"}], " ", "samples", " ", "are", 
    " ", "stored", "  ", "as", " ", "a", " ", "pair", " ", "in", " ", "the", 
    " ", "previously", " ", "defined", " ", 
    RowBox[{"table", "."}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"unisamples", "=", 
      RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"u", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], "]"}]}], " ", ";", 
     "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"RandomReal", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "up"}], "}"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pair", "=", 
      RowBox[{"{", 
       RowBox[{"u", ",", "y"}], "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"unisamples", ",", "pair"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Gammtab", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", "unisamples"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "n"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.891101518199578*^9, 3.8911015333494987`*^9}, {
  3.8912499806584888`*^9, 3.8912499834972744`*^9}, {3.891251071586887*^9, 
  3.89125107684768*^9}, {3.8912541271065454`*^9, 3.8912541290939007`*^9}},
