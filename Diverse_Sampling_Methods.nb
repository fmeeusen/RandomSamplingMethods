Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Recall", " ", "the", " ", "definition", " ", "of", " ", "the", " ", 
    "inverse", " ", "CDF", " ", "of", " ", "the", " ", "Exponential", " ", 
    RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Expon", "[", "u_", "]"}], "=", 
    FractionBox[
     RowBox[{"-", 
      RowBox[{"Log", "[", 
       RowBox[{"1", "-", "u"}], "]"}]}], "\[Lambda]"]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.890386222672186*^9, 3.890386284703391*^9}, 
   3.890386322477588*^9, {3.8903867547704363`*^9, 3.8903867801295996`*^9}, {
   3.890561414702732*^9, 3.8905614151968265`*^9}, {3.8909661257894835`*^9, 
   3.890966167963149*^9}, {3.8909664290441055`*^9, 3.890966429230861*^9}, 
   3.890966930879473*^9},
 CellLabel->
  "In[292]:=",ExpressionUUID->"6cb4e9df-0070-4406-a85d-41806d9486df"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "defines", " ", "an", " ", "empty", " ", "table", " ", "with",
     " ", "intially", " ", "0", " ", "rows", " ", "and", " ", 
    RowBox[{"columns", ".", " ", "It"}], " ", "will", " ", "be", " ", "used", 
    " ", "to", " ", "store", " ", "the", " ", 
    RowBox[{"results", "."}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Poiss", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "u", "}"}], ",", " ", 
        RowBox[{
         RowBox[{"u", "=", 
          RowBox[{"RandomReal", "[", 
           RowBox[{"{", 
            RowBox[{"0", ",", "1"}], "}"}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"i", "=", "0"}], ";", "\[IndentingNewLine]", 
         RowBox[{"t", "=", 
          RowBox[{"Expon", "[", "u", "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
            RowBox[{
            "The", " ", "While", " ", "loop", " ", "below", " ", "continues", 
             " ", "until", " ", "t"}], " ", "\[GreaterEqual]", " ", 
            RowBox[{
            "1.", " ", "When", " ", "this", " ", "condition", " ", "is", " ", 
             "no", " ", "longer", " ", "met", " ", "the", " ", "loop", " ", 
             "stops"}]}], ",", " ", 
           RowBox[{
           "and", " ", "the", " ", "resulting", " ", "observations", " ", 
            "are", " ", "accepted", " ", "and", " ", "stored", " ", "in", " ",
             "the", " ", 
            RowBox[{"table", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{"t", "<", "1"}], ",", " ", 
           RowBox[{
            RowBox[{"i", "++"}], ";", "\[IndentingNewLine]", 
            RowBox[{"u", "=", 
             RowBox[{"RandomReal", "[", 
              RowBox[{"{", 
               RowBox[{"0", ",", "1"}], "}"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"t", "+=", 
             RowBox[{"Expon", "[", "u", "]"}]}], ";"}]}], "]"}], ";", 
         "\[IndentingNewLine]", "i"}]}], "]"}], ",", " ", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8903863253753815`*^9, 3.890386336027235*^9}, {
