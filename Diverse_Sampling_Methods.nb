      RowBox[{"n", "=", "50"}], ",", 
      RowBox[{"p", "=", "0.65"}], ",", 
      RowBox[{"nrepeats", "=", 
       SuperscriptBox["10", "4"]}]}], "}"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "is", " ", "just", " ", "a", " ", "Table", " ", "to", " ", 
     "store", " ", "the", " ", 
