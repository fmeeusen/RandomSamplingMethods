Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "The", " ", "proposed", " ", "distribution", " ", "now", " ", "becomes", 
    " ", "the", " ", "normalized", " ", "uniform", " ", "distribution", " ", 
    "with", " ", "the", " ", "range", " ", "of", " ", 
    RowBox[{"(", 
     RowBox[{"0", ",", "up"}], ")"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"g", "[", "x_", "]"}], "=", 
    FractionBox["1", "up"]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8912460407391777`*^9, 3.8912460506187735`*^9}, {
  3.8912511414312024`*^9, 3.8912511605515585`*^9}, {3.891251250507393*^9, 
  3.8912512523722773`*^9}},
 CellLabel->
  "In[260]:=",ExpressionUUID->"7525f7c8-2908-4581-aa39-2d1286985cf9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Now", " ", "compute", " ", "the", " ", "maximum", " ", "value", " ", 
     "of", " ", "this", " ", "distribution", " ", "and", " ", "set", " ", 
     "this", " ", "equal", " ", "to", " ", "the", " ", "value", " ", "for", 
     " ", "the", " ", "constant", " ", "c"}], ",", " ", 
    RowBox[{
    "to", " ", "make", " ", "sure", " ", "that", " ", "the", " ", "proposed", 
     " ", "distribution", " ", "completely", " ", "envelops", " ", 
     "\[IndentingNewLine]", "the", " ", "target", " ", 
     RowBox[{"distribution", "."}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"c", "=", 
    RowBox[{"First", "[", 
     RowBox[{"FindMaximum", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"f", "[", "x", "]"}], 
        RowBox[{"g", "[", "x", "]"}]], ",", "x"}], "]"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{
  3.8912512587965956`*^9, {3.891251305255685*^9, 3.8912513491691265`*^9}},
 CellLabel->
  "In[268]:=",ExpressionUUID->"e88b7973-423e-4864-9991-2d7d6a96c617"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "is", " ", "just", " ", "an", " ", "empty", " ", "table", " ",
     "of", " ", "\"\<n\>\"", " ", "elements", " ", "to", " ", "store", " ", 
    "the", " ", "results"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"exptab", "=", 
    RowBox[{"Table", "[", 
     RowBox[{",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]], "Input",
