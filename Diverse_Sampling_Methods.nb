Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "shape", " ", "parameters", " ", 
     "a", " ", "and", " ", "b"}], ",", " ", 
    RowBox[{
    "and", " ", "the", " ", "rate", " ", "parameter", " ", "\[Beta]", " ", 
     "for", " ", "the", " ", "random", " ", "variables", " ", 
     RowBox[{"X", "~", "Gamma"}], 
     RowBox[{"(", 
      RowBox[{"a", ",", "\[Beta]"}], ")"}]}], ",", " ", 
    RowBox[{
     RowBox[{"Y", "~", "Gamma"}], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"b", ",", "\[Beta]"}], ")"}], ".", " ", "Furthermore"}]}], ",",
     " ", 
    RowBox[{
    "the", " ", "number", " ", "of", " ", "iid", " ", "exponential", " ", 
     "distributions", " ", "is", " ", "defined", " ", "for", " ", 
     "generating", " ", "the", " ", "X", " ", 
     RowBox[{"(", "nexpx", ")"}], " ", "and", " ", "Y", " ", 
     RowBox[{"(", "nexpy", ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"a", "=", 
      RowBox[{"nexpx", "=", "2"}]}], ",", 
     RowBox[{"b", "=", 
      RowBox[{"nexpy", "=", "3"}]}], ",", 
     RowBox[{"\[Lambda]", "=", "3"}], ",", 
     RowBox[{"nobs", "=", 
      RowBox[{"5", "*", 
       SuperscriptBox["10", "4"]}]}]}], "}"}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8909233071330814`*^9, 3.890923479544672*^9}, {
  3.8909235657997384`*^9, 3.8909237840682583`*^9}, {3.8909238396235595`*^9, 
