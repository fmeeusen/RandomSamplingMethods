Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "defines", " ", "the", " ", "sample", " ", "size", " ", 
     RowBox[{"(", "n", ")"}]}], ",", " ", 
    RowBox[{"the", " ", "probability", " ", "for", " ", "success", " ", 
     RowBox[{"(", "p", ")"}], " ", "and", " ", "the", " ", "number", " ", 
     "of", " ", "times", " ", "the", " ", "experiment", " ", "is", " ", 
     "repeated", " ", 
     RowBox[{"(", "nrepeats", ")"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"n", "=", "50"}], ",", 
      RowBox[{"p", "=", "0.65"}], ",", 
      RowBox[{"nrepeats", "=", 
       SuperscriptBox["10", "4"]}]}], "}"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "is", " ", "just", " ", "a", " ", "Table", " ", "to", " ", 
     "store", " ", "the", " ", 
     RowBox[{"results", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"BinomDist", "=", 
     RowBox[{"Table", "[", 
      RowBox[{",", 
       RowBox[{"{", "nrepeats", "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "This", " ", "generates", " ", "a", " ", "sample", " ", "of", " ", 
       "size", " ", "n", " ", "from", " ", "the", " ", "Bernoulli", " ", 
       RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"bernsample", "=", 
        RowBox[{"RandomInteger", "[", 
         RowBox[{
          RowBox[{"BernoulliDistribution", "[", "p", "]"}], ",", 
          RowBox[{"{", "n", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", " ", 
        RowBox[{
        "This", " ", "takes", " ", "and", " ", "stores", " ", "the", " ", 
         "sample", " ", 
         RowBox[{"total", ":"}]}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{"y", "=", 
        RowBox[{"Total", "[", "bernsample", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"BinomDist", "[", 
         RowBox[{"[", "ii", "]"}], "]"}], "=", "y"}], ";"}], 
      "\[IndentingNewLine]", ",", 
      RowBox[{"{", 
       RowBox[{"ii", ",", "1", ",", "nrepeats"}], "}"}]}], "]"}], 
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.890620939215001*^9, 3.8906209397080383`*^9}, {
  3.8906212378949027`*^9, 3.8906214458080688`*^9}, {3.8906215551268253`*^9, 
  3.8906215637020645`*^9}, {3.890622137499936*^9, 3.890622149660847*^9}},
 CellLabel->"In[43]:=",ExpressionUUID->"9219b002-4c1f-45ac-a8ab-144b3e4853c2"],

