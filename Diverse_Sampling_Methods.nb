Cell[BoxData[
 RowBox[{
  RowBox[{"Do", "[", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "This", " ", "generates", " ", "a", " ", "sample", " ", "of", " ", "size",
      " ", "n", " ", "from", " ", "the", " ", "Bernoulli", " ", 
     RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"bernsample", "=", 
      RowBox[{"RandomInteger", "[", 
       RowBox[{
        RowBox[{"BernoulliDistribution", "[", 
         FractionBox["k", "n1"], "]"}], ",", 
        RowBox[{"{", "n2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"(*", " ", 
      RowBox[{
      "This", " ", "takes", " ", "and", " ", "stores", " ", "the", " ", 
       "sample", " ", 
       RowBox[{"total", ":"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"y", "=", 
      RowBox[{"Total", "[", "bernsample", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"HyperGeomdist", "[", 
       RowBox[{"[", "ii", "]"}], "]"}], "=", "y"}], ";"}], 
    "\[IndentingNewLine]", ",", 
    RowBox[{"{", 
     RowBox[{"ii", ",", "1", ",", "nrepeats"}], "}"}]}], "]"}], 
  ";"}]], "Input",
