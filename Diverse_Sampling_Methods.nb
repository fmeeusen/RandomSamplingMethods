Cell[CellGroupData[{

Cell["Poisson ", "Section",
 CellChangeTimes->{{3.890583862555746*^9, 3.890583893507901*^9}, 
   3.8905842004463177`*^9, 
   3.8909064481882133`*^9},ExpressionUUID->"ad22bbdf-aa59-4ba2-bb9f-\
173b3757af9c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "This", " ", "clears", " ", "all", " ", "definitions", " ", "and", " ", 
     "variables"}], ";", " ", 
    RowBox[{"Quit", " ", "Kernel"}]}], " ", "*)"}], "\n", 
  RowBox[{"ClearAll", "[", 
   RowBox[{"Evaluate", "[", 
    RowBox[{
     RowBox[{"Context", "[", "]"}], "<>", "\"\<*\>\""}], "]"}], 
   "]"}]}]], "Input",
 CellLabel->"In[13]:=",ExpressionUUID->"fbf49868-bbf1-42de-9617-e04cf929ba91"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "defines", " ", "the", " ", "value", " ", "for", " ", "the", 
    " ", "rate", " ", 
    RowBox[{"(", "\[Lambda]", ")"}], " ", "and", " ", "the", " ", "sample", 
    " ", "size", " ", 
    RowBox[{"(", "n", ")"}], " ", "respectively"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", "=", 
      SuperscriptBox["10", "5"]}], ",", " ", 
     RowBox[{"\[Lambda]", "=", "7"}]}], "}"}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8909065190810747`*^9, 3.8909065652179947`*^9}, {
  3.8909071035816765`*^9, 3.8909071100664434`*^9}},
 CellLabel->"In[14]:=",ExpressionUUID->"3edd641e-949e-4d08-bb2b-b7637a672be0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "This", " ", "generates", " ", "a", " ", "sample", " ", "of", " ", "size", 
    " ", "n", " ", "from", " ", "the", " ", "unity", " ", "unfiform", " ", 
    RowBox[{"distribution", ":"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"U", "=", 
    RowBox[{"RandomReal", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"0", ",", "1"}], "}"}], ",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.8903667500073395`*^9, 3.890366792052748*^9}, {
  3.890369762609439*^9, 3.890369762954757*^9}, {3.8909065781964054`*^9, 
  3.8909066038119287`*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"cca6cc1b-aa66-4314-b8c0-0b0fff924ef5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "This", " ", "transforms", " ", "U", " ", "into", " ", "a", " ", "sample", 
    " ", "of", " ", "the", " ", "Exponential", " ", "distribution", " ", 
    "using", " ", "the", " ", "ITM"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"\[CapitalDelta]t", "=", 
    FractionBox[
     RowBox[{"-", 
      RowBox[{"Log", "[", 
       RowBox[{"1", "-", "U"}], "]"}]}], "\[Lambda]"]}], ";"}]}]], "Input",
 CellChangeTimes->{{3.890366257673295*^9, 3.8903662741716156`*^9}, {
  3.8903663070522423`*^9, 3.8903664224728613`*^9}, {3.8903666159809475`*^9, 
  3.890366674022007*^9}, {3.890366707425649*^9, 3.8903667455293417`*^9}, {
  3.890367533307028*^9, 3.890367580615539*^9}, {3.890369843396513*^9, 
  3.890369849795538*^9}, {3.8907156535372314`*^9, 3.8907156848417253`*^9}, {
  3.89090663472138*^9, 3.890906674071571*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"3d97c5f0-c18e-4171-bc26-bcf40c2c2a27"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "This", " ", "transforms", " ", "the", " ", "sample", " ", "from", " ", 
     "the", " ", "Exponential", " ", "distribution", " ", "into", " ", "that",
      " ", "of", " ", "a", " ", "Poisson"}], ",", " ", 
    RowBox[{
    "by", " ", "using", " ", "the", " ", "method", " ", "described", " ", 
     "in", " ", "the", " ", "report"}]}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"T", "=", 
    RowBox[{"Floor", "[", 
     RowBox[{"Accumulate", "[", "\[CapitalDelta]t", "]"}], "]"}]}], 
   ";"}]}]], "Input",
 CellChangeTimes->{{3.890715717070529*^9, 3.8907158117874517`*^9}, {
  3.890715842009034*^9, 3.890715862056725*^9}, {3.8907159941654553`*^9, 
  3.890715999345314*^9}, {3.8907160431832566`*^9, 3.890716048278631*^9}, {
  3.8907450221252766`*^9, 3.8907450598465714`*^9}, {3.8909067005124006`*^9, 
  3.890906753466236*^9}},
 CellLabel->"In[17]:=",ExpressionUUID->"70b1c0ac-e3bc-478f-bc0f-4d7b1435375e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Counting", " ", "the", " ", "number", " ", "of", " ", "Poisson", " ", 
    "event", " ", "for", " ", "each", " ", "time", " ", "integer"}], " ", 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{"units", ",", "counts"}], "}"}], "=", 
